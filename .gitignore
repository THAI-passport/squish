# Virtualenvs -- run-local.sh recreates this. 274 MB of platform-specific
# binaries that will not run on anyone else's machine.
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Runtime output
squish.log
*.log

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp

# Vendored pdf.js -- fetched by backend/static/vendor/fetch-pdfjs.sh or at
# Docker build. Large minified blobs; keep them out of the diff. The script and
# README in that folder ARE tracked.
backend/static/vendor/pdf.min.js
backend/static/vendor/pdf.worker.min.js

# Local overrides
.env
docker-compose.override.yml
